# Environment file template
# Copy this to .env and fill in your values

# Required: Clarifai API Key (Personal Access Token)
CLARIFAI_API_KEY=your_api_key_here

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Output directory for generated files
OUTPUT_DIR=projects

# Optional: Configuration directory
CONFIG_DIR=config
