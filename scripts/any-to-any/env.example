###############################################
# Clarifai Local Runner Environment Variables #
###############################################

# Required: Personal Access Token (create in Clarifai portal)
CLARIFAI_PAT=replace_with_pat

# Required: Your Clarifai user id (account username)
CLARIFAI_USER_ID=replace_with_user

# Required: Target App ID for the model (will be created if missing)
CLARIFAI_APP_ID=replace_with_app

# Required: Model ID you want to bind to the runner
CLARIFAI_MODEL_ID=replace_with_model

# Required: Model type id (e.g. multimodal-to-text, text-classifier, etc.)
CLARIFAI_MODEL_TYPE_ID=multimodal-to-text

# Required: Deployment ID (maps model version to compute)
CLARIFAI_DEPLOYMENT_ID=replace_with_deployment

# Required: Compute cluster and nodepool IDs (will be created if missing)
CLARIFAI_COMPUTE_CLUSTER_ID=replace_with_compute_cluster
CLARIFAI_NODEPOOL_ID=replace_with_nodepool

# Optional: Logging level for script output
LOG_LEVEL=INFO

###############################################