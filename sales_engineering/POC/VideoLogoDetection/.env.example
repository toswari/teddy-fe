# Copy this file to `.env` and update the secrets before running the app or demo scripts.
# Clarifai PATs are managed in the Clarifai console under Settings > Secrets.

# Required for any Clarifai SDK/gRPC calls.
CLARIFAI_PAT=replace-with-your-pat

# Defaults to Clarifai's public app; override if you are targeting a custom workspace.
CLARIFAI_USER_ID=clarifai
CLARIFAI_APP_ID=main

# Defaults to Clarifai's Logo Detection V2 model.
CLARIFAI_MODEL_ID=logo-detection-v2
CLARIFAI_MODEL_VERSION_ID=09f3acb13bde404592c81254c5d87ae1

# Optional helper used by scripts/demo_logo_detection.py when --image-url is omitted.
CLARIFAI_TEST_IMAGE=https://samples.clarifai.com/metro-north.jpg
