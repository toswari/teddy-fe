# AI Brand Compliance Specialist - Environment Setup
# 
# This project uses the conda environment: brand-logo-312
#
# Quick commands:
# - Activate environment: conda activate brand-logo-312
# - Or use helper script: ./conda_run.sh <command>
#
# Examples:
# ./conda_run.sh test     # Run tests
# ./conda_run.sh app      # Start application  
# ./conda_run.sh install  # Install dependencies
#
# For manual activation in current shell:
# conda activate brand-logo-312

# Auto-activation check
if [ -n "$BASH_VERSION" ] || [ -n "$ZSH_VERSION" ]; then
    if [ "$CONDA_DEFAULT_ENV" != "brand-logo-312" ]; then
        echo "🐍 Tip: This project uses conda environment 'brand-logo-312'"
        echo "   Run: conda activate brand-logo-312"
        echo "   Or use: ./conda_run.sh <command>"
    fi
fi
