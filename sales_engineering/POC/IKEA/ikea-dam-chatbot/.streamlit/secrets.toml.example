# Template for Streamlit secrets configuration
# Copy this file to .streamlit/secrets.toml and fill in your actual values
# DO NOT commit secrets.toml to version control

[clarifai]
# Get your Personal Access Token (PAT) from: https://clarifai.com/settings/security
PAT = "your_clarifai_api_key_here"

# Note: All other configuration has been moved to .streamlit/config.toml
# This file should only contain sensitive information like API keys
