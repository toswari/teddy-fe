# Clarifai Configuration
# Replace with your actual values from Clarifai platform

# Your Clarifai User ID
CLARIFAI_USER_ID=roomplanner-org

# Your Clarifai App ID  
CLARIFAI_APP_ID=furniture-bed

# Your Clarifai Personal Access Token
# Get this from your Clarifai account settings
CLARIFAI_PAT="your_personal_access_token_here"

# Batch processing configuration
# Number of images to process in each batch (recommended: 8-32)
# Smaller batches = more API calls but better error recovery
# Larger batches = fewer API calls but longer processing times
BATCH_SIZE=32