# === CONCEPT ID SANITIZATION FUNCTION ===
# Clarifai has strict rules for concept IDs, so we need to clean them up
def sanitize_concept_id(concept_name):
    """
    Clean up concept names to make them valid for Clarifai.
    
    For beginners: Clarifai concept IDs can only contain:
    - Letters (a-z, A-Z)
    - Numbers (0-9) 
    - Hyphens (-)
    
    This function takes any concept name and converts it to follow these rules.
    
    Examples:
    - "Twin Bed" becomes "twin-bed"
    - "KING SIZE" becomes "king-size" 
    - "Queen_Bed_XL" becomes "queen-bed-xl"
    
    Args:
        concept_name (str): The original concept name from CSV
        
    Returns:
        str: A cleaned concept ID that Clarifai will accept
    """
    # Handle empty or None input
    if not concept_name:
        return ""
    
    # Step 1: Remove leading/trailing whitespace
    sanitized = concept_name.strip()
    
    # Step 2: Replace spaces with hyphens (Clarifai doesn't allow spaces)
    sanitized = sanitized.replace(' ', '-')
    
    # Step 3: Replace underscores with hyphens (normalize to one separator type)
    sanitized = sanitized.replace('_', '-')
    
    # Step 4: Remove any characters that aren't letters, numbers, or hyphens
    # This uses "regular expressions" - a pattern matching tool
    import re  # Import regex library
    sanitized = re.sub(r'[^a-zA-Z0-9-]', '', sanitized)
    
    # Step 5: Clean up multiple consecutive hyphens (---, --, etc. become -)
    sanitized = re.sub(r'-+', '-', sanitized)
    
    # Step 6: Remove leading/trailing hyphens (remove - from start and end)
    sanitized = sanitized.strip('-')
    
    # Step 7: Handle edge case where we might end up with empty string
    if not sanitized:
        sanitized = "unknown-concept"  # Fallback name
    
    # Step 8: Convert to lowercase for consistency (Clarifai best practice)
    return sanitized.lower()

