# Copy this file to .env and adjust paths/ports as needed

# Root directory that holds MP4 inputs
MEDIA_ROOT="./media"

# Directory for generated MPEG-DASH outputs (defaults to MEDIA_ROOT/dash if omitted)
DASH_ROOT="./media/dash"

# FastAPI backend configuration
BACKEND_PORT=8000
BACKEND_URL="http://localhost:${BACKEND_PORT}"
CHUNK_SIZE_BYTES=1048576
LOG_LEVEL=DEBUG

# Streamlit UI
UI_PORT=8501
AUTO_OPEN_UI=1
MAX_CONCURRENT_PLAYERS=4

# DASH retention (days); set 0 to disable cleanup
DASH_RETENTION_DAYS=0

# Scripts options
SKIP_PORT_CHECK=0

# Optional API auth placeholders
# API_KEY=""
# AUTH_JWT_PUBLIC_KEY=""
